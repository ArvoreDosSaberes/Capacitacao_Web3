        <dc:title>Learn Ethereum: Build your own decentralized applications with Ethereum and smart contracts</dc:title>
        <dc:creator opf:file-as="Wu, Xun &amp; Zou, Zhihong &amp; Song, Dongying" opf:role="aut">Xun (Brian) Wu</dc:creator>
